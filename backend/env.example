# Database runtime
DB_DRIVER=postgres
DATABASE_URL=postgres://user:password@postgres:5432/pulse
SQLITE_PATH=./pulseguard.db
DB_LOG_LEVEL=error

REDIS_URL=localhost:6379

# Confirmation window defaults (applied when resource payload omits these fields)
CONFIRMATION_CHECKS=2
CONFIRMATION_INTERVAL=30

# Intelligent alerting defaults (applied when resource/component payload omits these fields)
FLAP_DETECTION_ENABLED=true
FLAP_THRESHOLD=4
FLAP_WINDOW_SECONDS=600
FLAP_MAX_DURATION_MINUTES=30
REMINDER_INTERVAL_MINUTES=0
GROUPING_WINDOW_SECONDS=30

# Scheduler mode (timingwheel for sqlite/community, asynq for hosted with Redis)
SCHEDULER_MODE=asynq

# Scheduler configuration (for timingwheel mode only)
SCHEDULER_TICK_INTERVAL=1s
SCHEDULER_MAX_WORKERS=10
SCHEDULER_SHUTDOWN_TIMEOUT=15s
SCHEDULER_NOTIFICATION_QUEUE_SIZE=100

PORT=8080

# Static files serving (SPA - Single Page Application)
# Path to serve Vue.js frontend from (relative or absolute)
STATIC_DIR=./static

# Authentication (JWT-based)
AUTH_EMAIL=admin@pulseguard.test
AUTH_PASSWORD=puls3gu@rd
JWT_SECRET=pulseguard-secret-key-change-in-production
