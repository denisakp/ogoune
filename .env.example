# =============================================================================
# Ogoune — Environment Variables Reference
# =============================================================================
# Copy this to .env and fill in your values before starting the application.
# Generate secrets with: openssl rand -hex 32
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
PORT=8080

# ---------------------------------------------------------------------------
# Database runtime
# ---------------------------------------------------------------------------
DB_DRIVER=postgres
DATABASE_URL=postgres://user:password@postgres:5432/pulse
SQLITE_PATH=./ogoune.db
DB_LOG_LEVEL=error

# ---------------------------------------------------------------------------
# Redis (required for hosted/Asynq scheduler mode)
# ---------------------------------------------------------------------------
REDIS_URL=localhost:6379

# ---------------------------------------------------------------------------
# Scheduler
# ---------------------------------------------------------------------------
# Use "asynq" for hosted PostgreSQL+Redis deployments, "timingwheel" for
# community SQLite deployments (in-process, no Redis required).
SCHEDULER_MODE=asynq
SCHEDULER_TICK_INTERVAL=1s
SCHEDULER_MAX_WORKERS=10
SCHEDULER_SHUTDOWN_TIMEOUT=15s
SCHEDULER_NOTIFICATION_QUEUE_SIZE=100

# ---------------------------------------------------------------------------
# Static files (SPA — Vue.js frontend)
# Path from which the binary serves built frontend assets.
# Default: web/dist (relative to repo root when running locally)
# In container: overridden to /app/static via docker-compose.
# ---------------------------------------------------------------------------
STATIC_DIR=web/dist

# ---------------------------------------------------------------------------
# Authentication (JWT-based)
# ---------------------------------------------------------------------------
AUTH_EMAIL=admin@ogoune.test
AUTH_PASSWORD=ogu3n3@rd
JWT_SECRET=ogoune-secret-key-change-in-production

# ---------------------------------------------------------------------------
# Confirmation window defaults
# ---------------------------------------------------------------------------
CONFIRMATION_CHECKS=2
CONFIRMATION_INTERVAL=30

# ---------------------------------------------------------------------------
# Intelligent alerting defaults
# ---------------------------------------------------------------------------
FLAP_DETECTION_ENABLED=true
FLAP_THRESHOLD=4
FLAP_WINDOW_SECONDS=600
FLAP_MAX_DURATION_MINUTES=30
REMINDER_INTERVAL_MINUTES=0
GROUPING_WINDOW_SECONDS=30

# ---------------------------------------------------------------------------
# Expiry alerting
# ---------------------------------------------------------------------------
EXPIRY_ALERT_THRESHOLDS=30,14,7,1

# ---------------------------------------------------------------------------
# Webhooks
# ---------------------------------------------------------------------------
WEBHOOK_URL=
WEBHOOK_SIGNATURE=

# ---------------------------------------------------------------------------
# Credential encryption (pkg/crypto — for future credential-at-rest hardening)
# Generate with: openssl rand -hex 32   (produces a 64-char hex string)
# Required only by features that actively use pkg/crypto; not needed for
# normal app startup in this release.
# ---------------------------------------------------------------------------
APP_SECRET_KEY=

# ---------------------------------------------------------------------------
# Open Core edition detection
# Leave empty for Community Edition.
# Enterprise license keys begin with "pg_ent_".
# ---------------------------------------------------------------------------
ENTERPRISE_LICENSE_KEY=

# ---------------------------------------------------------------------------
# Docker Compose (hosted stack) — used by docker-compose.yml only
# ---------------------------------------------------------------------------
APP_PORT=8080
PG_USERNAME=ogoune
PG_PASSWORD=password
PG_DATABASE=ogoune
