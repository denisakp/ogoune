# =============================================================================
# Ogoune — Environment Variables Reference
# =============================================================================
# Copy this to .env and fill in your values before starting the application.
# Generate secrets with: openssl rand -hex 32
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_PORT=9596

# Application environment: "development" or "production".
# Controls conditional behavior such as HSTS header emission.
# HSTS is only sent when APP_ENV=production or the request arrives over TLS.
APP_ENV=development

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Output format: "json" (structured, default) or "text" (human-readable).
LOG_FORMAT=json

# Minimum log level: "debug", "info" (default), "warn", "error".
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Database runtime
# ---------------------------------------------------------------------------
DB_DRIVER=postgres
DATABASE_URL=postgres://user:password@postgres:5432/pulse
SQLITE_PATH=./ogoune.db
DB_LOG_LEVEL=error

# ---------------------------------------------------------------------------
# Redis (required for hosted/Asynq scheduler mode)
# ---------------------------------------------------------------------------
REDIS_URL=localhost:6379

# ---------------------------------------------------------------------------
# Scheduler
# ---------------------------------------------------------------------------
# Use "asynq" for hosted PostgreSQL+Redis deployments, "timingwheel" for
# community SQLite deployments (in-process, no Redis required).
SCHEDULER_MODE=asynq
SCHEDULER_TICK_INTERVAL=1s
SCHEDULER_MAX_WORKERS=10
SCHEDULER_SHUTDOWN_TIMEOUT=15s
SCHEDULER_NOTIFICATION_QUEUE_SIZE=100

# ---------------------------------------------------------------------------
# ICMP monitoring (optional)
# ICMP monitoring is opt-in because raw ICMP sockets depend on host/container
# capabilities that are not universally available by default.
# false: HTTP/TCP/DNS only (default, unchanged behavior)
# true:  enable ICMP monitor creation and ICMP-backed incident diagnostics
# If capability is missing, Ogoune still starts and reports ICMP unavailable.
# ---------------------------------------------------------------------------
ENABLE_ICMP=false

# ---------------------------------------------------------------------------
# Static files (SPA — Vue.js frontend)
# Path from which the binary serves built frontend assets.
# Default: web/dist (relative to repo root when running locally)
# In container: overridden to /app/static via docker-compose.
# ---------------------------------------------------------------------------
STATIC_DIR=web/dist

# ---------------------------------------------------------------------------
# Authentication (JWT-based)
# ---------------------------------------------------------------------------
AUTH_EMAIL=zoltar@ogoune.test
AUTH_PASSWORD=S4ysM4k3YourW1sh!
JWT_SECRET=zoltar-says-make-your-wish

# ---------------------------------------------------------------------------
# Confirmation window defaults
# ---------------------------------------------------------------------------
CONFIRMATION_CHECKS=2
CONFIRMATION_INTERVAL=30

# ---------------------------------------------------------------------------
# Intelligent alerting defaults
# ---------------------------------------------------------------------------
FLAP_DETECTION_ENABLED=true
FLAP_THRESHOLD=4
FLAP_WINDOW_SECONDS=600
FLAP_MAX_DURATION_MINUTES=30
REMINDER_INTERVAL_MINUTES=0
GROUPING_WINDOW_SECONDS=30

# ---------------------------------------------------------------------------
# Expiry alerting
# ---------------------------------------------------------------------------
EXPIRY_ALERT_THRESHOLDS=30,14,7,1

# ---------------------------------------------------------------------------
# Webhooks
# ---------------------------------------------------------------------------
WEBHOOK_URL=
WEBHOOK_SIGNATURE=

# ---------------------------------------------------------------------------
# Credential encryption — REQUIRED. App refuses to start if missing or malformed.
# Generate with: openssl rand -hex 32   (produces a 64-char hex string)
# WARNING: Losing this key makes all stored notification channel credentials
# permanently unrecoverable. Back up this key securely alongside your database.
# ---------------------------------------------------------------------------
APP_SECRET_KEY=

# ---------------------------------------------------------------------------
# Open Core edition detection
# Leave empty for Community Edition.
# Enterprise license keys begin with "pg_ent_".
# ---------------------------------------------------------------------------
ENTERPRISE_LICENSE_KEY=

# ---------------------------------------------------------------------------
# Docker Compose (hosted stack) — used by docker-compose.yml only
# ---------------------------------------------------------------------------
PG_USERNAME=ogoune
PG_PASSWORD=password
PG_DATABASE=ogoune


# ---------------------------------------------------------------------------
# Prometheus Metrics Endpoint
# ---------------------------------------------------------------------------
# Enable the /metrics endpoint for Prometheus scraping (disabled by default).
# When false, the route is not registered and Prometheus will receive a 404.
ENABLE_METRICS=false

# Optional bearer token to protect the /metrics endpoint.
# When set, requests must include "Authorization: Bearer <token>" or receive 401.
# When left empty and ENABLE_METRICS=true, the endpoint is unauthenticated —
# a startup warning is logged. Only leave empty on private/firewalled networks.
METRICS_TOKEN=

# ---------------------------------------------------------------------------
# Security: CORS
# ---------------------------------------------------------------------------
# Comma-separated list of allowed origins for cross-origin requests.
# When empty, all cross-origin requests are rejected (same-origin only).
# Example: https://app.example.com,https://staging.example.com
CORS_ALLOWED_ORIGINS=

# ---------------------------------------------------------------------------
# Security: Rate Limiting
# ---------------------------------------------------------------------------
# Format: <count>/<duration> — e.g., 10/1m means 10 requests per minute.
# RATE_LIMIT_AUTH applies to /auth/* endpoints (login, 2FA, etc.).
# RATE_LIMIT_GLOBAL applies to all authenticated endpoints.
RATE_LIMIT_AUTH=10/1m
RATE_LIMIT_GLOBAL=100/1m

# Enable Swagger UI at /api/v1/docs/*
# Set to true only in development or staging environments.
# In production, keep this false to avoid exposing API documentation publicly.
ENABLE_SWAGGER=false

# ---------------------------------------------------------------------------
# Note: as of v2.0.0 the legacy SQLC_* env flags (SQLC_TAGS, SQLC_RESOURCE,
# SQLC_INCIDENT, ... 16 flags) are deprecated and silently ignored by the
# binary. sqlc is the only ORM. If your .env still has them set, no action
# needed — they're inert. You may delete them at your convenience.

# ---------------------------------------------------------------------------
# Custom Domains: SSL provisioning strategy (spec 059 FR-030 / FR-040)
# ---------------------------------------------------------------------------
# Drives the wording shown on /settings/org/domain and the ssl_status lifecycle.
# Allowed values: letsencrypt | external | disabled. Invalid value = fail-fast at startup.
#   - external (default): UI says "Configure your reverse proxy". ssl_status stays "none".
#   - letsencrypt: UI says "Provisioning Let's Encrypt cert (~5 min)". Note: the
#     provisioning→active transition (ACME issuance callback) is deferred per FR-040;
#     ssl_status stays "provisioning" until a follow-up ships the ACME client.
#   - disabled: SSL panel hidden entirely on the domain page.
SSL_PROVIDER=external

# ---------------------------------------------------------------------------
# App base URL — used to render the magic-link URL in 2FA reset emails (FR-012a).
# ---------------------------------------------------------------------------
APP_BASE_URL=http://localhost:5173
