{
  "name": "ogoune",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js",
      "esbuild",
      "vue-demi"
    ]
  },
  "author": "Denis AKPAGNONITE",
  "description": "Ogoune ui built with vuejs",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "test": "vitest run",
    "type-check": "vue-tsc --build",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore",
    "lint:eslint": "eslint . --fix",
    "lint": "run-s lint:*",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@ant-design/icons-vue": "7.0.1",
    "@iconify/vue": "^5.0.1",
    "@nuxt/ui": "^4.8.1",
    "@tiptap/core": "^3.26.0",
    "@tiptap/extension-link": "^3.26.0",
    "@tiptap/extension-task-item": "^3.26.0",
    "@tiptap/extension-task-list": "^3.26.0",
    "@tiptap/pm": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "@tiptap/vue-3": "^3.26.0",
    "@vuepic/vue-datepicker": "^11.0.0",
    "@vueuse/core": "^11.0.0",
    "ant-design-vue": "~4.2.6",
    "axios": "1.12.2",
    "cron-parser": "^5.5.0",
    "cronstrue": "^3.14.0",
    "dayjs": "^1.11.19",
    "dompurify": "^3.4.8",
    "install": "0.13.0",
    "ky": "^2.0.2",
    "pinia": "^3.0.3",
    "qrcode": "^1.5.4",
    "vue": "^3.5.22",
    "vue-router": "4",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@prettier/plugin-oxc": "^0.0.4",
    "@tailwindcss/vite": "^4.0.0",
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^22.18.6",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.33.0",
    "eslint-plugin-oxlint": "~1.11.0",
    "eslint-plugin-vue": "~10.4.0",
    "jiti": "^2.5.1",
    "jsdom": "^25.0.1",
    "msw": "^2.6.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.11.0",
    "prettier": "3.6.2",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.0",
    "unplugin-vue-components": "29.1.0",
    "vite": "^7.1.7",
    "vite-plugin-vue-devtools": "^8.0.2",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.1.0"
  }
}
